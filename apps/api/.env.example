APP_NAME=Tenue API
APP_ENV=development

# Database target selection.
# Leave TENUE_DB_TARGET unset for local development; the API will use local Supabase Postgres:
# postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres
TENUE_DB_TARGET=local

# Only set DATABASE_URL when explicitly targeting a remote database.
# Remote runtime usage requires TENUE_DB_TARGET=remote.
# Remote migrations additionally require TENUE_ALLOW_REMOTE_MIGRATIONS=1 in the shell that runs the migration command.
# DATABASE_URL=postgresql+psycopg://postgres.<project_ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Local Supabase API gateway default.
SUPABASE_URL=http://127.0.0.1:54321

# Preferred modern key name. Older setups can still use SUPABASE_ANON_KEY.
SUPABASE_PUBLISHABLE_KEY=REPLACE_WITH_SUPABASE_PUBLISHABLE_OR_ANON_KEY
# SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_PUBLISHABLE_OR_ANON_KEY

SUPABASE_AUTH_TIMEOUT_SECONDS=10

# Hosted Supabase example using the session pooler:
# TENUE_DB_TARGET=remote
# DATABASE_URL=postgresql+psycopg://postgres.<project_ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
# SUPABASE_URL=https://<project_ref>.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# If the password contains special characters, URL-encode it before placing it in DATABASE_URL.

# Local object storage for later phases.
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_CONSOLE_URL=http://127.0.0.1:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tenue-dev
MINIO_REGION=us-east-1

# Closet image processing.
CLOSET_MEDIA_DOWNLOAD_TTL_SECONDS=300
CLOSET_THUMBNAIL_MAX_EDGE=512
CLOSET_BACKGROUND_REMOVAL_PROVIDER=disabled
PHOTOROOM_API_KEY=
PHOTOROOM_BASE_URL=https://sdk.photoroom.com/v1/segment
PHOTOROOM_TIMEOUT_SECONDS=30
